#!/usr/bin/env bb
{:doap/name        "remember-batch"
 :doap/description "Store multiple insights in one operation"
 :dc/creator       "Claude"
 :spai/args        "\"text1\" \"text2\" ... [+topic/name ...]"
 :spai/tags        #{:memory :agent}}

;; spai remember-batch "insight 1" "insight 2" "insight 3" +spoqe/architecture
;;
;; Sends all texts in one (memory/remember-batch! [...] {:topic ...}) call.
;; Single INSERT DATA — no round-trip per insight.

(require '[clojure.string :as str]
         '[cheshire.core :as json]
         '[babashka.curl :as curl])

(def spoqe-url (or (System/getenv "SPOQE_MEMORY_URL") "http://localhost:4242"))

(defn query-spoqe [edn-command]
  (try
    (let [response (curl/post (str spoqe-url "/query")
                              {:headers {"Content-Type" "application/edn"
                                        "Accept" "application/json"}
                               :body (pr-str edn-command)
                               :throw false})]
      (if (= 200 (:status response))
        (json/parse-string (:body response))
        (do
          (println "Error:" (:status response) (:body response))
          nil)))
    (catch Exception e
      (binding [*out* *err*]
        (println "Cannot reach memory server at" spoqe-url)
        (println "Start: cd spoqe-memory && ./START-MEMORY.sh"))
      nil)))

(let [args *command-line-args*]
  (when (or (empty? args) (= (first args) "--help"))
    (println "Usage: spai remember-batch \"text1\" \"text2\" ... [+topic/name ...]")
    (println "")
    (println "Stores multiple insights in one INSERT DATA operation.")
    (println "All insights share the same topic tags.")
    (println "")
    (println "Examples:")
    (println "  spai remember-batch \"insight one\" \"insight two\"")
    (println "  spai remember-batch \"a\" \"b\" \"c\" +spoqe/architecture")
    (System/exit (if (empty? args) 1 0)))

  (let [raw-topics (->> args
                       (filter #(str/starts-with? % "+")))
        bad-topics (filter #(str/includes? % ":") raw-topics)]
    (when (seq bad-topics)
      (println "Error: topics must use / not : as separator")
      (println "  Bad:" (str/join ", " bad-topics))
      (println "  Fix:" (str/join ", " (map #(str/replace % ":" "/") bad-topics)))
      (System/exit 1)))
  (let [topics (->> args
                    (filter #(str/starts-with? % "+"))
                    (mapv #(keyword (subs % 1))))
        texts (->> args
                   (remove #(str/starts-with? % "+"))
                   (vec))
        opts (when (seq topics)
               {:topic (first topics)})
        cmd (if opts
              (list 'memory/remember-batch! texts opts)
              (list 'memory/remember-batch! texts))
        result (query-spoqe cmd)]
    (if-let [ids (get result "ids")]
      (do
        (println (str "Remembered " (count ids) " insights:"))
        (doseq [[text id] (map vector texts ids)]
          (println (str "  [" id "] " text)))
        (when (seq topics)
          (println (str "  topics: " (str/join ", " (map #(str "+" (namespace %) "/" (name %)) topics))))))
      (if (= "success" (get result "status"))
        (println (str "Remembered " (count texts) " insights"))
        (do
          (println "Failed to save insights")
          (System/exit 1))))))
