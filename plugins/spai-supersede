#!/usr/bin/env bb
{:doap/name        "supersede"
 :doap/description "Replace an insight with improved text (knowledge compression)"
 :dc/creator       "Claude"
 :spai/args        "\"old-uuid\" \"new text\" [+topic/name ...]"
 :spai/tags        #{:memory :agent}}

;; spai supersede "abc-uuid" "improved insight text" +spoqe/architecture
;;
;; Creates a new insight and marks the old one as superseded (dcterms:replaces).
;; Superseded insights are hidden from default `spai memory` listing.
;; Use `spai memory --all` to see everything including superseded.

(require '[clojure.string :as str]
         '[cheshire.core :as json]
         '[babashka.curl :as curl])

(def spoqe-url (or (System/getenv "SPOQE_MEMORY_URL") "http://localhost:4242"))

(defn query-spoqe [edn-command]
  (try
    (let [response (curl/post (str spoqe-url "/query")
                              {:headers {"Content-Type" "application/edn"
                                        "Accept" "application/json"}
                               :body (pr-str edn-command)
                               :throw false})]
      (if (= 200 (:status response))
        (json/parse-string (:body response))
        (do
          (binding [*out* *err*]
            (println "Error:" (:status response) (:body response)))
          nil)))
    (catch Exception e
      (binding [*out* *err*]
        (println "Cannot reach memory server at" spoqe-url)
        (println "Start: cd spoqe-memory && ./START-MEMORY.sh"))
      nil)))

(let [args *command-line-args*]
  (when (or (< (count args) 2) (= (first args) "--help"))
    (println "Usage: spai supersede \"old-uuid\" \"new text\" [+topic/name ...]")
    (println "")
    (println "Replaces an old insight with improved text.")
    (println "The old insight is marked as superseded (hidden from default listing).")
    (println "")
    (println "Examples:")
    (println "  spai supersede \"abc-123\" \"Better wording of the insight\"")
    (println "  spai supersede \"abc-123\" \"Refined understanding\" +spoqe/architecture")
    (System/exit (if (< (count args) 2) 1 0)))

  (let [old-uuid (first args)
        remaining (rest args)
        topics (->> remaining
                    (filter #(str/starts-with? % "+"))
                    (mapv #(keyword (subs % 1))))
        text (->> remaining
                  (remove #(str/starts-with? % "+"))
                  (str/join " "))
        opts (when (seq topics)
               {:topic (first topics)})
        cmd (if opts
              (list 'memory/supersede! old-uuid text opts)
              (list 'memory/supersede! old-uuid text))
        result (query-spoqe cmd)]
    (if-let [new-id (get result "new_id")]
      (do
        (println (str "Superseded: " old-uuid " -> " new-id))
        (println (str "  New text: " text)))
      (if (= "success" (get result "status"))
        (println (str "Superseded successfully"))
        (println "Failed to supersede insight")))))
